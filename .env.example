# ─── API Anthropic (Claude) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Ads API ────────────────────────────────────────────────────────
# Chemin vers le fichier google-ads.yaml (optionnel si les variables ci-dessous sont définies)
# GOOGLE_ADS_YAML_PATH=google-ads.yaml

# ID du compte Google Ads (ex: 123-456-7890 ou 1234567890)
GOOGLE_ADS_CUSTOMER_ID=

# OAuth2 — créer via Google Cloud Console
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Token développeur Google Ads API (Google Ads > Outils > Centre API)
GOOGLE_ADS_DEVELOPER_TOKEN=

# Compte MCC (manager) si applicable — laisser vide sinon
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
