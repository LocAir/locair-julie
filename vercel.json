{
  "cleanUrls": true,
  "crons": [
    { "path": "/api/cron-daily",   "schedule": "0 6 * * *"   },
    { "path": "/api/cron-weekly",  "schedule": "0 7 * * 1"   },
    { "path": "/api/cron-monthly", "schedule": "0 7 1 * *"   }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    },
    "api/cron-daily.js":   { "maxDuration": 30 },
    "api/cron-weekly.js":  { "maxDuration": 15 },
    "api/cron-monthly.js": { "maxDuration": 20 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(cgv|mentions-legales|confidentialite|404|retard)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(admin|transporteur)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
